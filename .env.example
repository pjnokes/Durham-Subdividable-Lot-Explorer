# ──────────────────────────────────────────────
# Durham Subdividable Lots — Local Dev Environment
# ──────────────────────────────────────────────
# Copy this to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Postgres (used by docker-compose) ──
POSTGRES_DB=durham_lots
POSTGRES_USER=durham
POSTGRES_PASSWORD=<your-dev-password>

# ── App database URLs (pydantic Settings, env_prefix=DURHAM_) ──
DURHAM_DATABASE_URL=postgresql+asyncpg://durham:<your-dev-password>@localhost:5432/durham_lots
DURHAM_DATABASE_URL_SYNC=postgresql+psycopg2://durham:<your-dev-password>@localhost:5432/durham_lots

# ── Ingestion / cron scripts (plain DATABASE_URL) ──
DATABASE_URL=postgresql://durham:<your-dev-password>@localhost:5432/durham_lots

# ── FastAPI ──
ENVIRONMENT=dev

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
