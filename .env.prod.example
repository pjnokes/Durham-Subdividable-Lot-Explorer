# ──────────────────────────────────────────────
# Durham Subdividable Lots — Production Environment
# ──────────────────────────────────────────────
# Copy to .env and fill in real values before deploying.

# ── Postgres ──
POSTGRES_DB=durham_lots
POSTGRES_USER=durham
POSTGRES_PASSWORD=CHANGE_ME_to_a_real_password

# ── App database URLs ──
DURHAM_DATABASE_URL=postgresql+asyncpg://durham:CHANGE_ME_to_a_real_password@db:5432/durham_lots
DURHAM_DATABASE_URL_SYNC=postgresql+psycopg2://durham:CHANGE_ME_to_a_real_password@db:5432/durham_lots

# ── Ingestion / cron scripts ──
DATABASE_URL=postgresql://durham:CHANGE_ME_to_a_real_password@db:5432/durham_lots

# ── FastAPI ──
ENVIRONMENT=production

# ── CORS (your Lightsail domain) ──
ALLOWED_ORIGINS=https://yourdomain.com
